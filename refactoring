import java.util.List;
import java.util.ArrayList;

public class ListConverter {

    public void convertUserList(List<String> list, String title) {
        List<String> upperCaseUsers = new ArrayList<>();
        for (String item : list) {
            upperCaseUsers.add(item.toUpperCase());
        }
        System.out.println(title + "： " + upperCaseUsers);
    }


    public static void main(String[] args) {
        ListConverter converter = new ListConverter();

        List<String> users = List.of("harry", "ron", "hermione");
        List<String> orders = List.of("order123", "order456", "order789");

        converter.convertUserList(users, "ユーザー名（大文字変換）");
        converter.convertOrderList(orders, "注文情報（大文字変換）");
    }
}
